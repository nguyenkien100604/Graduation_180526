# Sao chép thành .env ở thư mục gốc dự án và chỉnh theo SSMS của bạn
# Ví dụ máy hiện tại (SSMS): DESKTOP-3D0VNE9 — default instance
DB_SERVER=DESKTOP-3D0VNE9
DB_NAME=GraduationBanking
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUSTED_CONNECTION=yes

# Nếu dùng SQL Authentication thay vì Windows Auth:
# DB_TRUSTED_CONNECTION=no
# DB_USER=sa
# DB_PASSWORD=your_password

DB_SCHEMA=dbo
DB_TABLE_TRANSACTIONS=Transactions
DB_TABLE_BACKUP=Transactions_Backup
DB_TABLE_ISOLATION=IsolationOutput
DB_TABLE_RFM=RankRFM

# --- AI (chọn 1 hoặc nhiều; AI_PROVIDER=auto thử lần lượt khi hết quota) ---
# Free khuyến nghị: Groq https://console.groq.com (đăng ký → API Keys)
AI_PROVIDER=auto
AI_PROVIDER_ORDER=groq,google

# Groq — free tier, không cần thẻ (2025)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Google AI Studio — free có giới hạn/ngày https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_MODEL_FALLBACKS=gemini-1.5-flash-8b,gemini-2.0-flash-lite


